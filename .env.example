# Sakshi — environment configuration (example)
#
# Copy this file to `.env` and fill in real values. The `.env` file is
# gitignored and MUST NEVER be committed. Never place a real API key in this
# example file.

# --- Required ---
# Google Gemini API key, used by extract/gemini.py for schema-constrained
# extraction, classification, and summarization of ALREADY-PUBLIC text only.
GEMINI_API_KEY=your-key-here

# --- Optional ---
# Daily cap on Gemini tokens. The pipeline stops issuing new extraction calls
# once this cap is reached in a given run-day, protecting cost. Integer tokens.
# GEMINI_DAILY_TOKEN_CAP=2000000

# User-Agent sent with every outbound HTTP request. Must honestly name the
# project and its repository URL so source operators can identify and contact
# us. Requests are rate-limited to at most 1 request / 2s per host.
# USER_AGENT=SakshiBot/1.0 (+https://github.com/the-sakshi-project/sakshi)
